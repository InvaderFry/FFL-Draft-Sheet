{
  "compilerOptions": {
    /* Type-check only — Vite handles transpilation/bundling. */
    "noEmit": true,

    /* Language / module target tuned for Vite's bundler resolution. */
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,

    /* Strictness — the whole point of the migration. */
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Incremental coexistence: allow .js alongside .ts, but don't type-check
       the not-yet-migrated .js/.jsx files (checkJs: false). Components stay
       JS for now and consume the typed utils/hooks without being checked. */
    "allowJs": true,
    "checkJs": false,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}
